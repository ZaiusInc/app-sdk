{
  "name": "@zaiusinc/app-sdk",
  "version": "2.0.0-beta.1",
  "description": "Optimizely Connect Platform App SDK and interfaces",
  "repository": "https://github.com/ZaiusInc/app-sdk",
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    }
  ],
  "author": "Optimizely",
  "files": [
    "dist/",
    "src/"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {},
  "scripts": {
    "build": "yarn update-schema && tsc",
    "build-watch": "tsc -w",
    "lint": "npx eslint 'src/**/*.ts'",
    "test": "jest -i",
    "update-schema": "ts-json-schema-generator -p 'src/**/*.ts' -t AppManifest --no-type-check --no-top-ref -o ./src/app/types/AppManifest.schema.json && ts-json-schema-generator -p 'src/**/*.ts' -t SchemaObject --no-type-check --no-top-ref -o ./src/app/types/SchemaObject.schema.json",
    "prepare-readme-export": "node scripts/prepare_readme_export.js",
    "generate-docs": "typedoc --plugin typedoc-plugin-markdown ./src/index.ts && yarn prepare-readme-export"
  },
  "engines": {
    "node": ">=18.0"
  },
  "dependencies": {
    "@zaiusinc/app-forms-schema": "^2.0.0-beta.1",
    "ajv": "^8.17.1",
    "cron-expression-validator": "^1.0.20",
    "csv-parser": "^3.2.0",
    "deep-freeze": "^0.0.1",
    "email-validator": "^2.0.4",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.0",
    "jsonpath": "^1.1.1",
    "node-fetch": "^2.7.0",
    "object-hash": "^3.0.0",
    "remark": "^15.0.1",
    "remark-validate-links": "^13.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/deep-freeze": "^0.1.5",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonpath": "^0.2.4",
    "@types/lodash": "^4.17.16",
    "@types/mdast": "^4.0.4",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^22.13.9",
    "@types/node-fetch": "^2.6.12",
    "@types/object-hash": "^3.0.6",
    "@types/url-regex-safe": "^1.0.2",
    "@zaiusinc/eslint-config-presets": "^2.0.0-beta.5",
    "@zaiusinc/node-sdk": "^2.0.0-beta.1",
    "eslint": "^9.21.0",
    "eslint-config-love": "^119.0.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.4",
    "jest": "^29.7.0",
    "lodash": "^4.17.21",
    "mock-fs": "^5.5.0",
    "nock": "^14.0.1",
    "prettier": "^3.5.3",
    "slugify": "^1.6.6",
    "ts-jest": "^29.2.6",
    "ts-json-schema-generator": "^2.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "peerDependencies": {
    "@zaiusinc/node-sdk": "^2.0.0-beta.1"
  },
  "resolutions": {
    "@babel/core": "^7.26.10"
  }
}
