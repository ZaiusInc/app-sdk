{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "AppCategory": {
      "enum": [
        "Commerce Platform",
        "Point of Sale",
        "Lead Capture",
        "Advertising",
        "Marketing",
        "Channel",
        "Loyalty & Rewards",
        "Customer Experience",
        "Analytics & Reporting",
        "Surveys & Feedback",
        "Reviews & Ratings",
        "Content Management",
        "Data Quality & Enrichment",
        "Productivity",
        "CRM",
        "Accounting & Finance",
        "CDP / DMP",
        "Attribution & Linking",
        "Testing & Utilities",
        "Personalization & Content",
        "Offers",
        "Merchandising & Products",
        "Site & Content Experience",
        "Subscriptions"
      ],
      "type": "string"
    },
    "AppConsumer": {
      "additionalProperties": false,
      "properties": {
        "batch_size": {
          "type": "number"
        },
        "batch_timeout": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      },
      "required": [
        "entry_point",
        "description"
      ],
      "type": "object"
    },
    "AppFunction": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        },
        "global": {
          "type": "boolean"
        },
        "installation_resolution": {
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string"
            },
            "type": {
              "enum": [
                "GUID",
                "HEADER",
                "QUERY_PARAM",
                "JSON_BODY_FIELD"
              ],
              "type": "string"
            }
          },
          "required": [
            "type",
            "key"
          ],
          "type": "object"
        }
      },
      "required": [
        "entry_point",
        "description"
      ],
      "type": "object"
    },
    "AppJob": {
      "additionalProperties": false,
      "properties": {
        "cron": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/definitions/ValueHash"
        }
      },
      "required": [
        "entry_point",
        "description"
      ],
      "type": "object"
    },
    "AppLiquidExtension": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        },
        "input": {
          "additionalProperties": {
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "type": {
                "enum": [
                  "string",
                  "number",
                  "boolean",
                  "any"
                ],
                "type": "string"
              }
            },
            "required": [
              "type",
              "required",
              "description"
            ],
            "type": "object"
          },
          "type": "object"
        }
      },
      "required": [
        "entry_point",
        "description"
      ],
      "type": "object"
    },
    "AppRuntime": {
      "enum": [
        "node12",
        "node18",
        "node18_rt"
      ],
      "type": "string"
    },
    "AttributableMetric": {
      "enum": [
        "open",
        "click",
        "engage",
        "delivery"
      ],
      "type": "string"
    },
    "CampaignTargeting": {
      "additionalProperties": false,
      "description": "Defines the targeting requirements for a channel.",
      "properties": {
        "event_data": {
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": "Any additional data to include on the events generated by the campaign run.",
          "type": "object"
        },
        "identifier": {
          "description": "The customer identifier field to target.",
          "type": "string"
        }
      },
      "required": [
        "identifier"
      ],
      "type": "object"
    },
    "ChannelRateLimit": {
      "additionalProperties": false,
      "description": "Defines a rate limit for channel delivery in to form of <count> per <n> <unit> where unit is `second`, `minute`, `hour`, `day`, or <number> of seconds. E.g., count: 100, period: 15, unit: second => 100 per 15 seconds",
      "properties": {
        "count": {
          "description": "The number of delivery requests (batches) per period of time",
          "type": "number"
        },
        "grouping": {
          "description": "Whether this rate limit applies to the app as a whole or per each install",
          "enum": [
            "app",
            "install"
          ],
          "type": "string"
        },
        "period": {
          "description": "The number of units of time to measure the rate limit over",
          "type": "number"
        },
        "unit": {
          "description": "The unit of time applied to the perioid",
          "enum": [
            "second",
            "minute",
            "hour",
            "day"
          ],
          "type": "string"
        }
      },
      "required": [
        "count",
        "period",
        "unit",
        "grouping"
      ],
      "type": "object"
    },
    "ChannelType": {
      "enum": [
        "email",
        "app_push",
        "web_push",
        "web_modal",
        "web_embed",
        "sms",
        "api",
        "direct_mail",
        "whatsapp",
        "facebook_messenger",
        "ad",
        "segment_sync",
        "test_channel"
      ],
      "type": "string"
    },
    "DeliveryMetric": {
      "enum": [
        "sent",
        "delivery",
        "delivery_unknown"
      ],
      "type": "string"
    },
    "DisengagementMetric": {
      "enum": [
        "disengage",
        "opt-out",
        "spam_report",
        "list_unsubscribe"
      ],
      "type": "string"
    },
    "EngagementMetric": {
      "enum": [
        "open",
        "click",
        "engage"
      ],
      "type": "string"
    },
    "ReachabilityMetric": {
      "enum": [
        "hard_bounce",
        "soft_bounce"
      ],
      "type": "string"
    },
    "Value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/ValueHash"
        }
      ],
      "description": "A value type that is safe to write to any storage option"
    },
    "ValueHash": {
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/definitions/Value"
          },
          {
            "items": {
              "$ref": "#/definitions/Value"
            },
            "type": "array"
          },
          {
            "not": {}
          }
        ]
      },
      "description": "An object with some restrictions. An interface that follows the ValueHash interface can be safely written to any storage option.",
      "type": "object"
    }
  },
  "properties": {
    "channel": {
      "additionalProperties": false,
      "properties": {
        "delivery": {
          "additionalProperties": false,
          "properties": {
            "batch_size": {
              "type": "number"
            },
            "concurrent_batches": {
              "type": "number"
            },
            "rate_limits": {
              "items": {
                "$ref": "#/definitions/ChannelRateLimit"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "metrics": {
          "additionalProperties": false,
          "properties": {
            "attributable": {
              "items": {
                "$ref": "#/definitions/AttributableMetric"
              },
              "type": "array"
            },
            "delivery": {
              "items": {
                "$ref": "#/definitions/DeliveryMetric"
              },
              "type": "array"
            },
            "disengagement": {
              "items": {
                "$ref": "#/definitions/DisengagementMetric"
              },
              "type": "array"
            },
            "engagement": {
              "items": {
                "$ref": "#/definitions/EngagementMetric"
              },
              "type": "array"
            },
            "reachability": {
              "items": {
                "$ref": "#/definitions/ReachabilityMetric"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "options": {
          "additionalProperties": false,
          "properties": {
            "prepare": {
              "type": "boolean"
            },
            "template_preview": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "targeting": {
          "anyOf": [
            {
              "const": "dynamic",
              "type": "string"
            },
            {
              "items": {
                "$ref": "#/definitions/CampaignTargeting"
              },
              "type": "array"
            }
          ]
        },
        "type": {
          "$ref": "#/definitions/ChannelType"
        }
      },
      "required": [
        "type",
        "targeting"
      ],
      "type": "object"
    },
    "consumers": {
      "additionalProperties": {
        "$ref": "#/definitions/AppConsumer"
      },
      "type": "object"
    },
    "environment": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "functions": {
      "additionalProperties": {
        "$ref": "#/definitions/AppFunction"
      },
      "type": "object"
    },
    "jobs": {
      "additionalProperties": {
        "$ref": "#/definitions/AppJob"
      },
      "type": "object"
    },
    "liquid_extensions": {
      "additionalProperties": {
        "$ref": "#/definitions/AppLiquidExtension"
      },
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "app_id": {
          "type": "string"
        },
        "availability": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "categories": {
          "items": {
            "$ref": "#/definitions/AppCategory"
          },
          "type": "array"
        },
        "contact_email": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "support_url": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "app_id",
        "display_name",
        "version",
        "vendor",
        "support_url",
        "summary",
        "contact_email",
        "categories",
        "availability"
      ],
      "type": "object"
    },
    "outbound_domains": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "runtime": {
      "$ref": "#/definitions/AppRuntime"
    }
  },
  "required": [
    "meta",
    "runtime"
  ],
  "type": "object"
}